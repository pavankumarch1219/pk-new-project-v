#!/bin/sh
# Maven Wrapper Script
set -e

# Find the project base dir (where .mvn folder is)
find_maven_basedir() {
  BASEDIR=$(dirname "$0")
  BASEDIR=$(cd "$BASEDIR" && pwd)
  echo "$BASEDIR"
}

MAVEN_PROJECTBASEDIR=$(find_maven_basedir)
export MAVEN_PROJECTBASEDIR

WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_PROPS="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

# Read distribution URL
DOWNLOAD_URL=$(grep "distributionUrl" "$WRAPPER_PROPS" | cut -d'=' -f2 | tr -d '\r\n')

MAVEN_USER_HOME="${MAVEN_USER_HOME:-$HOME/.m2}"
MAVEN_VERSION=$(echo "$DOWNLOAD_URL" | sed 's/.*apache-maven-\([0-9.]*\)-.*/\1/')
MAVEN_HOME="$MAVEN_USER_HOME/wrapper/dists/apache-maven-$MAVEN_VERSION-bin/*/apache-maven-$MAVEN_VERSION"

# Use system maven if wrapper download fails
if command -v mvn > /dev/null 2>&1; then
  exec mvn "$@"
fi

exec java -jar "$WRAPPER_JAR" "$@"
